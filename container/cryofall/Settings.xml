<?xml version="1.0" encoding="utf-8"?>
<!--
  CryoFall Dedicated Server — Default Configuration
  Managed by Game Server Admin (GSA).

  This file is the canonical schema-backing for profiles/cryofall.a2ml.
  Field names here map 1:1 to @field(key=...) declarations in the A2ML profile.
  GSA's config_extract FFI layer reads and writes this file; edit via the
  GSA Gossamer GUI (Config Editor panel) rather than directly, so that changes
  are tracked in VeriSimDB with full drift detection.

  Administrator access
  ─────────────────────
  Joshua Jewell is a designated server administrator.  To grant in-game admin
  rights after the server is running, use the server console:
    /op <character-name>
  or add the Steam ID to the Operators section below (comment → uncomment).

  Operators section (CryoFall Automaton engine format):
    <Operators>
      <Operator steamId="JOSHUA_STEAM_ID_HERE" />
      <Operator steamId="JONATHAN_STEAM_ID_HERE" />
    </Operators>

  Replace JOSHUA_STEAM_ID_HERE / JONATHAN_STEAM_ID_HERE with actual 64-bit
  Steam IDs.  Find yours at steamcommunity.com/id/<vanityurl>?xml=1
  or via `steamid.io`.

  Connection details (Verpex VPS)
  ──────────────────────────────────
  Host:      cryofall.jewell.nexus (DNS grey-cloud — not Cloudflare proxied)
  Game port: UDP 6000
  Discovery: UDP 6001
  IP:        209.42.26.106
-->
<server-settings>

  <!-- ── Server identity ─────────────────────────────────────────────── -->
  <!--
    ServerName        Displayed in the in-game server browser
    ServerDescription Short description shown in the browser listing
  -->
  <ServerName>Jewell Family Server</ServerName>
  <ServerDescription>Private CryoFall server — Jonathan and Joshua Jewell. Managed by GSA.</ServerDescription>

  <!-- ── Network ────────────────────────────────────────────────────── -->
  <!--
    ServerPort    UDP port for game traffic (must match firewall + DNS record)
    MaxPlayers    Keep low on constrained VPS (3.6 GB RAM, shared with other services)
  -->
  <ServerPort>6000</ServerPort>
  <MaxPlayers>10</MaxPlayers>

  <!-- ── Access control ────────────────────────────────────────────── -->
  <!--
    IsPrivate       true = hidden from public server browser
    ServerPassword  Password players need to join; empty = open to password-less join
                    Since IsPrivate=true the server won't appear publicly regardless.
  -->
  <IsPrivate>true</IsPrivate>
  <ServerPassword></ServerPassword>

  <!-- ── World lifecycle ───────────────────────────────────────────── -->
  <!--
    WipePeriodDays  0 = no automatic wipe; set to e.g. 30 for a fresh map monthly
  -->
  <WipePeriodDays>0</WipePeriodDays>

  <!-- ── Gameplay ──────────────────────────────────────────────────── -->
  <!--
    IsPvE             true = players cannot damage each other (family-friendly)
    IsRaidsEnabled    false = raiding disabled (only meaningful in PvP mode)
    WelcomeMessage    Shown to each player on connect
  -->
  <IsPvE>true</IsPvE>
  <IsRaidsEnabled>false</IsRaidsEnabled>
  <WelcomeMessage>Welcome to the Jewell family server. Build freely — nobody will raid you here.</WelcomeMessage>

  <!-- ── Rates ─────────────────────────────────────────────────────── -->
  <!--
    Multipliers > 1.0 give faster progression — useful for a private server
    where you want to explore content without the grind of a public server.
    These are all set to 2× as a starting point; adjust via the GSA Config
    Editor panel (changes tracked in VeriSimDB for drift detection).
  -->
  <ServerRates>
    <GatheringSpeedMultiplier>2.0</GatheringSpeedMultiplier>
    <LearningSpeedMultiplier>2.0</LearningSpeedMultiplier>
    <CraftingSpeedMultiplier>2.0</CraftingSpeedMultiplier>
  </ServerRates>

  <!-- ── Administrators ────────────────────────────────────────────── -->
  <!--
    Uncomment and fill in Steam IDs after confirming them.
    Jonathan D.A. Jewell and Joshua Jewell are both operators.
    Find Steam IDs at: https://steamid.io/
  -->
  <Operators>
    <Operator steamId="76561198149527024"  name="pengie5" />
    <Operator steamId="76561198141836018"  name="hyperpolymath" />
  </Operators>

</server-settings>
