{
  "id": "gsa-config-history",
  "title": "Config History",
  "description": "Config version timeline with diff viewer and provenance chain",
  "version": "0.1.0",
  "author": "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>",
  "license": "PMPL-1.0-or-later",
  "runtime": "gossamer",
  "dimensions": { "width": 1400, "height": 900, "resizable": true },
  "entry": "../../src/gui/panels/config-history/panel.html",
  "data_sources": [
    { "id": "history-data", "uri": "gossamer://gsa/history", "refresh_interval_ms": 0 }
  ],
  "widgets": [
    { "type": "timeline", "data_source": "history-data", "fields": [
      { "field": "version", "label": "Version" },
      { "field": "timestamp", "label": "Time" },
      { "field": "actor", "label": "Actor" },
      { "field": "description", "label": "Description" }
    ]},
    { "type": "diff-viewer", "data_source": "history-data", "mode": "side-by-side" },
    { "type": "data-table", "data_source": "history-data", "subtitle": "Provenance Chain", "fields": [
      { "field": "event_type", "label": "Event" },
      { "field": "actor", "label": "Actor" },
      { "field": "description", "label": "Description" },
      { "field": "timestamp", "label": "Time" },
      { "field": "hash", "label": "Hash", "truncate": 12 }
    ]},
    { "type": "action-bar", "actions": [
      { "id": "rollback", "label": "Rollback to Selected", "icon": "undo", "style": "warning", "confirm": true }
    ]}
  ],
  "tags": ["history", "timeline", "diff", "provenance", "rollback", "temporal"]
}
